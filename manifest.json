{
  "manifest_version": 3,
  "name": "OnlineStore CH risk-check.",
  "version": "1.0.4",
  "browser_specific_settings": {
    "gecko": {
      "id": "onlinestore-ch-riskcheck@baweibel.ch",
      "data_collection_permissions": {
        "required": [
          "browsingActivity"
        ]
      }
    }
  },
  "description": "Prüft Online-Shops gegen Warnlisten (K-Tipp/Saldo), Reklamationen & auf Trusted Shops Zertifizierung.",
  "default_locale": "de",
  "permissions": [
    "activeTab",
    "storage",
    "tabs",
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "OnlineStore CH risk-check",
    "default_icon": {
      "16": "src/icons/icon16.png",
      "48": "src/icons/icon48.png",
      "128": "src/icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "src/background/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/content.js"],
      "css": ["src/content/content.css"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "src/options/options.html",
  "icons": {
    "16": "src/icons/icon16.png",
    "48": "src/icons/icon48.png",
    "128": "src/icons/icon128.png"
  },
  "author": "baweibel.ch",
  "_cross_browser_note": "Chrome MV3 uses 'service_worker', while Firefox MV3 requires 'scripts'. package_xpi.sh handles this conversion automatically."
}
